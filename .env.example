# Joblantern environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------
JOBLANTERN_ADDR=:8080
JOBLANTERN_ENV=development
LOG_LEVEL=info

# Signed cookie secret. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=replace-me-with-32-bytes-base64

# ---------------------------------------------------------------------------
# Database (Postgres + PostGIS + pgvector)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://joblantern:joblantern@localhost:5432/joblantern?sslmode=disable

# ---------------------------------------------------------------------------
# LLM providers (configure at least one; see config/llm.yaml)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# MCP server upstream credentials
# ---------------------------------------------------------------------------
# Mapillary client token: https://www.mapillary.com/dashboard/developers
MAPILLARY_TOKEN=

# OpenCorporates API token: https://api.opencorporates.com/
OPENCORPORATES_TOKEN=

# OpenRouteService API key: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Telegram bot token (joblantern-bot). Create one via @BotFather.
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Self-hosted services (override when running in production)
# ---------------------------------------------------------------------------
NOMINATIM_URL=http://localhost:8088
OVERPASS_URL=http://localhost:8089/api/interpreter

# ---------------------------------------------------------------------------
# Observability (optional in dev)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=joblantern
